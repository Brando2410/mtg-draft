{
  "name": "mtg-draft-root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install-all": "npm install",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "npm start -w backend",
    "backend": "npm run dev -w backend",
    "frontend": "npm run dev -w frontend",
    "dev": "npx concurrently --kill-others \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}